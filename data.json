北归","章节英文":"Ch6: Return North","篇名":"《病中游祖堂山》","年份":"1101","年份排序":1101,"地点":"南京","经度":118.8,"纬度":32.06,"体裁":"诗","核心内容":"重病中坚持游寺，形体衰朽而精神清明","思想倾向":"偏佛家","儒":0,"道":1,"佛":4,"关键意象词":"禅、静、寂、生死看破","轶事/备注":"","地图弹窗摘句":""},{"序号":57,"章节":"第六章·北归","章节英文":"Ch6: Return North","篇名":"《答径山琳长老》","年份":"1101","年份排序":1101,"地点":"常州","经度":119.97,"纬度":31.77,"体裁":"文","核心内容":"临终前给高僧信，完全放下世间执念","思想倾向":"纯佛家","儒":0,"道":0,"佛":5,"关键意象词":"禅、空、虚、生死看破","轶事/备注":"弥留之际言\"勉强即乖\"","地图弹窗摘句":""},{"序号":58,"章节":"第六章·北归","章节英文":"Ch6: Return North","篇名":"《答钱济明书》（绝笔）","年份":"1101","年份排序":1101,"地点":"常州","经度":119.97,"纬度":31.77,"体裁":"文","核心内容":"绝笔信，灵魂将随风化去","思想倾向":"纯佛家","儒":0,"道":0,"佛":5,"关键意象词":"梦、幻、空、万物一体","轶事/备注":"苏轼卒于常州，享年六十六","地图弹窗摘句":""}],"chapters":[{"章节":"第一章·出川","时间跨度":"1056-1059","核心地点":"眉山→嘉州→三峡→江陵→汴京","思想总结":"儒家为主，道家为辅。少年得志、远行应试、立名天下的入世起点","地理特征":"从四川盆地沿长江东出，翻越三峡天险进入中原平原，路线呈东向上升","代表色":"青绿 #4DB6AC","scrollytelling叙述要点":"苏氏父子三人乘舟出川，沿江而下。山水壮阔激发功名壮志，\"飞鸿踏雪泥\"的隐喻已暗藏人生无常的伏笔"},{"章节":"第二章·京城与初仕","时间跨度":"1060-1071","核心地点":"汴京→凤翔→汴京→杭州","思想总结":"儒家最强，道家审美化萌芽。凤翔实干→丁忧→回京→变法冲突→出杭","地理特征":"中原腹地到关中再到江南，视野从庙堂转向山水，地理跨度东西展开","代表色":"月白 #B0BEC5","scrollytelling叙述要点":"从凤翔的喜雨亭到杭州的西湖，苏轼的笔触从朝堂民生逐渐融入江南审美。政治上的首次受挫，驱动了道佛思想的初探"},{"章节":"第三章·辗转外任","时间跨度":"1071-1079","核心地点":"杭州→密州→徐州→湖州","思想总结":"儒道并进。政务巅峰与旷达心态同步确立","地理特征":"从江南向北至山东、再南下至苏南，辗转于黄淮平原，地理上南北往复","代表色":"松花绿→暖黄","scrollytelling叙述要点":"密州出猎的豪放、中秋望月的婵娟、徐州抗洪的血性——儒家能量的最后一次全面爆发。但乌台诗案的阴影已在湖州逼近"},{"章节":"第四章·黄州突围","时间跨度":"1080-1084","核心地点":"黄州（黄冈）","思想总结":"道家最强，佛家显著上升，儒家未断。从\"政治人格\"向\"存在人格\"的核心跃迁","地理特征":"被贬至长江中游小城，地理空间骤然收缩为一城一坡一江，但精神空间无限扩展","代表色":"赭石 #D7CCC8","scrollytelling叙述要点":"从御史台的死牢到东坡的农田，苏轼被剥夺一切外在凭借后完成了最壮丽的精神突围。赤壁的江月、沙湖的烟雨——\"也无风雨也无晴\""},{"章节":"第五章·南渡岭南","时间跨度":"1094-1100","核心地点":"惠州→儋州","思想总结":"佛道更重，道家略强于佛。\"在野而不废世\"，日常中完成自我安顿","地理特征":"从中原急坠至岭南、再渡海至海南岛，地理上的最南端，也是精神的最深处","代表色":"墨色→紫灰","scrollytelling叙述要点":"年近花甲被贬蛮荒，日啖荔枝、松风亭顿悟、和陶归园——苏轼将被迫的流放转化为主动的归隐。在瘴疠之乡完成\"万物一体\"的终极安顿"},{"章节":"第六章·北归","时间跨度":"1100-1101","核心地点":"儋州→琼州海峡→镇江→常州","思想总结":"儒道佛融通后的总结态。不再是哪一家最强，而是三教圆融的澄明晚境","地理特征":"从海南北归，沿海路北上至江南，路线与出川形成对称回环，终于常州","代表色":"灰白 #ECEFF1","scrollytelling叙述要点":"渡海时\"天容海色本澄清\"，金山寺前\"问汝平生功业，黄州惠州儋州\"——北归的路线与出川形成完美回环，地理的归来即精神的圆成"}],"weights":[{"章节":"第一章·出川","儒家均值":3.4,"道家均值":1.3,"佛家均值":0.3,"作品数":8,"主导思想":"儒家主导","权重描述":"纯粹儒家入世，道家仅为审美表层"},{"章节":"第二章·京城与初仕","儒家均值":3,"道家均值":2.2,"佛家均值":0.6,"作品数":9,"主导思想":"儒强道起","权重描述":"儒家实干主导，杭州后道佛初探"},{"章节":"第三章·辗转外任","儒家均值":3.2,"道家均值":2.5,"佛家均值":0.3,"作品数":11,"主导思想":"儒道并进","权重描述":"政务巅峰与超然旷达并行"},{"章节":"第四章·黄州突围","儒家均值":1.1,"道家均值":3.2,"佛家均值":1.8,"作品数":12,"主导思想":"道家最强","权重描述":"精神跃迁核心期，佛家显著上升"},{"章节":"第五章·南渡岭南","儒家均值":0.5,"道家均值":3.5,"佛家均值":1.8,"作品数":12,"主导思想":"佛道见长","权重描述":"日常安顿，万物一体"},{"章节":"第六章·北归","儒家均值":0.7,"道家均值":1.7,"佛家均值":3,"作品数":6,"主导思想":"三教融通","权重描述":"灰木不系舟，勉强即乖"}],"imgs":[{"意象词":"自然","总频次":11,"第一章":3,"第二章":2,"第三章":1,"第四章":2,"第五章":3,"第六章":""},{"意象词":"社稷","总频次":4,"第一章":2,"第二章":1,"第三章":1,"第四章":"","第五章":"","第六章":""},{"意象词":"民生","总频次":4,"第一章":"","第二章":2,"第三章":2,"第四章":"","第五章":"","第六章":""},{"意象词":"空","总频次":4,"第一章":"","第二章":1,"第三章":"","第四章":"","第五章":1,"第六章":2},{"意象词":"随遇而安","总频次":4,"第一章":"","第二章":1,"第三章":"","第四章":2,"第五章":1,"第六章":""},{"意象词":"功业","总频次":3,"第一章":3,"第二章":"","第三章":"","第四章":"","第五章":"","第六章":""},{"意象词":"天地","总频次":3,"第一章":1,"第二章":"","第三章":1,"第四章":"","第五章":1,"第六章":""},{"意象词":"亭","总频次":3,"第一章":"","第二章":1,"第三章":1,"第四章":"","第五章":1,"第六章":""},{"意象词":"谏言","总频次":3,"第一章":"","第二章":2,"第三章":1,"第四章":"","第五章":"","第六章":""},{"意象词":"幻","总频次":3,"第一章":"","第二章":1,"第三章":"","第四章":"","第五章":1,"第六章":1},{"意象词":"禅","总频次":3,"第一章":"","第二章":1,"第三章":"","第四章":"","第五章":"","第六章":2},{"意象词":"万物一体","总频次":3,"第一章":"","第二章":"","第三章":"","第四章":"","第五章":2,"第六章":1},{"意象词":"生死看破","总频次":3,"第一章":"","第二章":"","第三章":"","第四章":"","第五章":1,"第六章":2},{"意象词":"治国","总频次":2,"第一章":1,"第二章":1,"第三章":"","第四章":"","第五章":"","第六章":""},{"意象词":"教化","总频次":2,"第一章":1,"第二章":"","第三章":"","第四章":"","第五章":1,"第六章":""},{"意象词":"济世","总频次":2,"第一章":1,"第二章":"","第三章":1,"第四章":"","第五章":"","第六章":""},{"意象词":"远行","总频次":2,"第一章":2,"第二章":"","第三章":"","第四章":"","第五章":"","第六章":""},{"意象词":"高台","总频次":2,"第一章":"","第二章